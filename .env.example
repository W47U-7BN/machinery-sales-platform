APP_NAME="Indo Industrial Machinery"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=id
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=id_ID

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Database Configuration
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=industrial_machinery
DB_USERNAME=root
DB_PASSWORD=

# Session Configuration
SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

# Broadcast, Filesystem & Queue
BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis

# Cache & Redis
CACHE_STORE=redis
CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# Mail Configuration
MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="info@perusahaan.com"
MAIL_FROM_NAME="${APP_NAME}"

# AWS (for S3 storage if used)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# Scout / Meilisearch
SCOUT_DRIVER=meilisearch
SCOUT_QUEUE=true
MEILISEARCH_HOST=http://127.0.0.1:7700
MEILISEARCH_KEY=

# Fortify / Auth
FORTIFY_TWO_FACTOR_ENABLED=true
FORTIFY_CONFIRM_PASSWORD_ENABLED=true

# Company Profile
COMPANY_NAME="PT Indo Industrial Machinery"
COMPANY_TAGLINE="Solusi Mesin Industri Terpercaya"
COMPANY_EMAIL=info@perusahaan.com
COMPANY_PHONE="(021) 1234-5678"
COMPANY_WHATSAPP=6281234567890
COMPANY_ADDRESS="Jl. Industri Raya No. 123"
COMPANY_CITY=Jakarta
COMPANY_ESTABLISHED_YEAR=2008

# Analytics & Tracking
GOOGLE_ANALYTICS_ID=
META_PIXEL_ID=
SEARCH_CONSOLE_VERIFICATION=
TRACK_VISITORS=true

# Vite
VITE_APP_NAME="${APP_NAME}"

# Reverb (WebSockets)
REVERB_APP_ID=
REVERB_APP_KEY=
REVERB_APP_SECRET=
REVERB_HOST="localhost"
REVERB_PORT=8080
REVERB_SCHEME=http

# Trusted Proxies
TRUSTED_PROXIES="*"
